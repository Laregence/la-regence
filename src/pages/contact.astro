---
import SidebarLayout from "../layouts/SidebarLayout.astro";

const title = "La Régence — Contact";
const description = "Horaires, réservation et contact de La Régence à Mont-de-Marsan.";
---

<SidebarLayout {title} {description} active="contact">
  <section class="min-h-screen w-full bg-[var(--color-bg)] px-4 sm:px-6 md:px-8 py-10">
    <div class="max-w-3xl mx-auto">

      <h1 class="font-limelight text-4xl md:text-5xl text-brand text-center">
        Contact
      </h1>

      <div class="mt-10 rounded-2xl soft-border bg-white/40 p-6 md:p-10">
        <!-- HORAIRES -->
        <h2 class="font-limelight text-2xl md:text-3xl text-brand text-center">
          <strong>HORAIRES</strong>
        </h2>

        <div class="mt-6 text-center text-slate-800 leading-relaxed text-lg">
          <p class="uppercase tracking-wide">DU LUNDI AU SAMEDI</p>
          <p class="mt-1 text-xl md:text-2xl font-semibold">7H30 – 00H00</p>

          <div class="mt-6">
            <p class="uppercase tracking-wide">REPAS DE 12H00 À 14H00</p>
            <p class="uppercase tracking-wide">ET DE 19H À 22H</p>
          </div>

          <div class="mt-8">
            <p class="text-lg md:text-xl">
              <strong>
                <a href="tel:+33558859272" class="underline hover:text-[var(--color-copper)] transition">
                  05 58 85 92 72
                </a>
              </strong>
            </p>
          </div>
        </div>

        <!-- Réservation -->
        <div class="mt-10 text-slate-800 leading-relaxed text-lg">
          <p class="font-limelight text-2xl text-brand text-center">
            <strong>Réservation</strong>
          </p>

          <div class="mt-4 space-y-4 text-center">
            <p>
              Si vous êtes un groupe de plus de 8 personnes, vous pouvez également nous contacter directement par écrit
              <a href="mailto:laregencemdm@gmail.com" class="underline hover:text-[var(--color-copper)] transition">
                laregencemdm@gmail.com
              </a>.
            </p>

            <p>
              Pour toute demande presse, autre requête ou si vous souhaitez vous joindre à notre équipe, n’hésitez pas à nous contacter en envoyant un message à
              <a href="mailto:laregencemdm@gmail.com" class="underline hover:text-[var(--color-copper)] transition">
                laregencemdm@gmail.com
              </a>.
            </p>
          </div>
        </div>

        <!-- Adresse -->
        <div class="mt-10 text-center text-slate-800 text-lg">
          <p>2 rue Léon Gambetta, 40 000 Mont de Marsan</p>
        </div>
      </div>
    </div>
  </section>
</SidebarLayout>