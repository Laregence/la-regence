---
const title = "Impression réservations — La Régence";
---

<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
  </head>

  <body>
  <h1 style="color:red">TEST ROUGE</h1>
    <main id="print-root">
      Chargement...
    </main>

    <script>
      import { supabase } from "../../lib/supabaseClient.js";

      const root = document.getElementById("print-root");
      const params = new URLSearchParams(window.location.search);

      const date = params.get("date");
      const service = params.get("service");

      function formatDate(dateStr) {
        const d = new Date(dateStr + "T00:00:00");
        return d.toLocaleDateString("fr-FR", {
          weekday: "long",
          day: "numeric",
          month: "long",
          year: "numeric",
        });
      }

      function formatHeure(heure) {
        return String(heure || "").slice(0, 5).replace(":", "h");
      }

      function labelSalle(value) {
        const labels = {
          peu_importe: "Peu importe",
          salle_bas: "Salle du bas",
          etage: "Étage",
          terrasse: "Terrasse",
        };
        return labels[value] || value || "-";
      }

      async function loadPrintReservations() {
        if (!date || !service) {
          root.innerHTML = "Date ou service manquant.";
          return;
        }

        const { data, error } = await supabase
          .from("reservations")
          .select("*")
          .eq("date_service", date)
          .eq("service", service)
          .neq("statut", "refusee")
          .order("heure", { ascending: true });

        if (error) {
          root.innerHTML = "Erreur : " + error.message;
          return;
        }

        const reservations = data || [];
        const totalCouverts = reservations.reduce(
          (sum, r) => sum + Number(r.nb_personnes || 0),
          0
        );

        root.innerHTML = `
          <section class="page">
            <header>
              <div>
                <h1>La Régence</h1>
                <p>Réservations ${service}</p>
              </div>

              <div class="date">
                ${formatDate(date)}
              </div>
            </header>

            <div class="summary">
              <strong>${reservations.length}</strong> réservation(s)
              · <strong>${totalCouverts}</strong> couvert(s)
            </div>

            <table>
              <thead>
                <tr>
                  <th>Heure</th>
                  <th>Nom</th>
                  <th>Couv.</th>
                  <th>✓</th>
                  <th>Salle</th>
                  <th>Téléphone</th>
                  <th>Commentaire</th>
                </tr>
              </thead>

              <tbody>
                ${
                  reservations.length
                    ? reservations.map((r) => `
                      <tr>
                        <td class="heure">${formatHeure(r.heure)}</td>
                        <td>${(r.nom || "").toUpperCase()} ${r.prenom || ""}</td>
                        <td class="center">${r.nb_personnes || ""}</td>
                        <td class="check-cell"></td>
                        <td>${labelSalle(r.preference_salle)}</td>
                        <td>${r.telephone || ""}</td>
                        <td>${r.commentaire_client || ""}</td>
                      </tr>
                    `).join("")
                    : `
                      <tr>
                        <td colspan="7" class="empty">
                          Aucune réservation pour ce service.
                        </td>
                      </tr>
                    `
                }
              </tbody>
            </table>

            <div class="notes">
              <h2>Notes service</h2>
              <div></div>
              <div></div>
              <div></div>
            </div>

            <button id="print-btn" onclick="window.print()">
              Imprimer / Exporter PDF
            </button>
          </section>
        `;
      }

      loadPrintReservations();
    </script>

    <style>

<style>

table,
th,
td {
  border: 2px solid red !important;
}

body {
  margin: 0;
  background: #f5efe6;
  font-family: Arial, sans-serif;
  color: #111827;

}   
  body {
    margin: 0;
    background: #f5efe6;
    font-family: Arial, sans-serif;
    color: #111827;
  }

  .page {
    max-width: 1100px;
    margin: 30px auto;
    background: white;
    padding: 32px;
    border-radius: 16px;
  }

  header {
    display: flex;
    justify-content: space-between;
    gap: 24px;
    border-bottom: 3px solid #25471f;
    padding-bottom: 16px;
    margin-bottom: 20px;
  }

  h1 {
    margin: 0;
    color: #25471f;
    font-size: 34px;
    text-transform: uppercase;
  }

  header p {
    margin: 4px 0 0;
    font-size: 20px;
    text-transform: uppercase;
  }

  .date {
    font-size: 22px;
    font-weight: bold;
    text-align: right;
    color: #25471f;
  }

  .summary {
    margin: 16px 0 24px;
    font-size: 20px;
  }

  table {
    width: 100%;
    border-collapse: collapse;
    font-size: 15px;
    border: 2px solid #25471f;
  }

  th {
    background: #25471f;
    color: white;
    text-align: left;
    padding: 10px;
    border: 1px solid #25471f;
  }

  td {
    border: 1px solid #cbd5e1;
    padding: 12px 10px;
    vertical-align: middle;
  }

  tbody tr:nth-child(even) {
    background: #f8fafc;
  }

  tbody tr:nth-child(odd) {
    background: #ffffff;
  }

  tbody tr {
    min-height: 42px;
  }

  /* Largeurs colonnes */

  th:nth-child(1),
  td:nth-child(1) {
    width: 90px;
  }

  th:nth-child(3),
  td:nth-child(3) {
    width: 70px;
    text-align: center;
  }

  th:nth-child(4),
  td:nth-child(4) {
    width: 42px;
    text-align: center;
  }

  th:nth-child(6),
  td:nth-child(6) {
    width: 140px;
  }

  .heure {
    font-weight: bold;
    color: #25471f;
    white-space: nowrap;
    font-size: 17px;
  }

  .center {
    text-align: center;
    font-weight: bold;
    font-size: 17px;
  }

  .check-cell {
    text-align: center;
  }

  .check-cell::before {
    content: "";
    display: inline-block;
    width: 18px;
    height: 18px;
    border: 2px solid #25471f;
    border-radius: 3px;
  }

  .empty {
    text-align: center;
    padding: 24px;
    color: #64748b;
  }

  .notes {
    margin-top: 32px;
  }

  .notes h2 {
    color: #25471f;
    font-size: 20px;
  }

  .notes div {
    height: 38px;
    border-bottom: 1px solid #ccc;
  }

  #print-btn {
    margin-top: 24px;
    background: #25471f;
    color: white;
    border: 0;
    padding: 14px 22px;
    border-radius: 10px;
    font-weight: bold;
    cursor: pointer;
  }

  @media print {
    body {
      background: white;
    }

    .page {
      margin: 0;
      max-width: none;
      padding: 0;
      border-radius: 0;
    }

    #print-btn {
      display: none;
    }

    tbody tr:nth-child(even) {
      background: #f1f5f9 !important;
      -webkit-print-color-adjust: exact;
      print-color-adjust: exact;
    }

    th {
      background: #25471f !important;
      color: white !important;
      -webkit-print-color-adjust: exact;
      print-color-adjust: exact;
    }
  }
</style>
  </body>
</html>