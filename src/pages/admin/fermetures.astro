---
import SidebarLayout from "../../layouts/SidebarLayout.astro";

const title = "Admin fermetures — La Régence";
const description = "Gestion des jours ouverts et fermés aux réservations.";
---

<SidebarLayout {title} {description}>
  <section class="min-h-screen w-full bg-[var(--color-bg)] px-6 py-10">
    <div class="max-w-5xl ml-auto text-right md:pr-12">
      <h1 class="font-limelight text-5xl text-brand tracking-wide uppercase">
        Fermetures
      </h1>

      <p class="mt-4 text-slate-700">
        Gérez les fermetures exceptionnelles et les ouvertures de dimanches.
      </p>

      <div id="login-box" class="mt-10 max-w-md ml-auto text-left space-y-4">
        <h2 class="font-limelight text-2xl text-brand text-right">Connexion admin</h2>

        <input id="login-email" type="email" placeholder="Email"
          class="w-full rounded-xl border border-brand/20 bg-white/60 px-4 py-3" />

        <input id="login-password" type="password" placeholder="Mot de passe"
          class="w-full rounded-xl border border-brand/20 bg-white/60 px-4 py-3" />

        <button id="login-btn"
          class="w-full font-limelight bg-brand text-white px-6 py-3 rounded-xl hover:bg-[var(--color-copper)] transition">
          Se connecter
        </button>

        <p id="login-message" class="text-sm text-red-700 text-right"></p>
      </div>

      <div id="admin-box" class="hidden mt-10">
        <div class="flex justify-end gap-3 mb-6">
          <a href="/admin/reservations"
            class="font-limelight border border-brand text-brand px-4 py-2 rounded-xl hover:bg-brand hover:text-white transition">
            Réservations
          </a>

          <button id="logout-btn"
            class="font-limelight border border-red-700 text-red-700 px-4 py-2 rounded-xl hover:bg-red-700 hover:text-white transition">
            Déconnexion
          </button>
        </div>

        <div class="rounded-2xl soft-border bg-white/50 p-5 text-left mb-8">
  <h2 class="font-limelight text-2xl text-brand text-right mb-4">
    Réservation en ligne
  </h2>

  <label class="flex items-center justify-between rounded-xl border border-brand/20 bg-white/60 px-4 py-3">
    <span>Réservations activées</span>
    <input id="booking-enabled" type="checkbox" class="w-5 h-5" />
  </label>

  <label class="block mt-4">
    <span class="text-sm uppercase text-slate-600">Message affiché si désactivé</span>
    <textarea id="booking-message" rows="3"
      class="mt-1 w-full rounded-xl border border-brand/20 bg-white/70 px-4 py-3"></textarea>
  </label>

  <div class="mt-5 text-right">
    <button id="save-booking-settings" type="button"
      class="font-limelight bg-brand text-white px-6 py-3 rounded-xl hover:bg-[var(--color-copper)] transition">
      Enregistrer le réglage
    </button>
  </div>

  <p id="booking-settings-message" class="mt-3 text-sm text-right"></p>
</div>
<div class="mt-8 rounded-2xl soft-border bg-white/40 p-4">
  <div class="flex items-center justify-between gap-4 mb-4">
    <button id="prev-month"
      class="rounded-xl border border-brand text-brand px-4 py-2 hover:bg-brand hover:text-white transition">
      ←
    </button>

    <h2 id="calendar-title" class="font-limelight text-3xl text-brand"></h2>

    <button id="next-month"
      class="rounded-xl border border-brand text-brand px-4 py-2 hover:bg-brand hover:text-white transition">
      →
    </button>
  </div>

  <div class="grid grid-cols-7 gap-2 text-center text-sm uppercase text-slate-600 mb-2">
    <div>Lun</div>
    <div>Mar</div>
    <div>Mer</div>
    <div>Jeu</div>
    <div>Ven</div>
    <div>Sam</div>
    <div>Dim</div>
  </div>

  <div id="calendar-grid" class="grid grid-cols-7 gap-2 text-left"></div>
</div>

        <form id="exception-form" class="rounded-2xl soft-border bg-white/50 p-5 text-left">
          <h2 class="font-limelight text-2xl text-brand text-right mb-5">
            Ajouter une exception
          </h2>

          <div class="grid grid-cols-2 md:grid-cols-4 gap-3 mb-5">
  <button type="button" id="close-day"
    class="rounded-xl bg-red-700 text-white px-4 py-3">
    Fermer journée
  </button>

  <button type="button" id="close-lunch"
    class="rounded-xl bg-orange-600 text-white px-4 py-3">
    Fermer midi
  </button>

  <button type="button" id="close-dinner"
    class="rounded-xl bg-orange-600 text-white px-4 py-3">
    Fermer soir
  </button>

  <button type="button" id="open-all"
    class="rounded-xl bg-green-700 text-white px-4 py-3">
    Tout ouvrir
  </button>
</div>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <label>
              <span class="text-sm uppercase text-slate-600">Date</span>
              <input id="date-service" type="date" required
                class="mt-1 w-full rounded-xl border border-brand/20 bg-white/70 px-4 py-3" />
                <p id="selected-date-label" class="mt-2 text-sm font-semibold text-brand"></p>
            </label>

            <label>
              <span class="text-sm uppercase text-slate-600">Motif</span>
              <input id="raison" type="text" placeholder="Fermeture exceptionnelle, ouverture dimanche..."
                class="mt-1 w-full rounded-xl border border-brand/20 bg-white/70 px-4 py-3" />
            </label>
          </div>

          <div class="mt-5 grid grid-cols-1 md:grid-cols-2 gap-4">
            <label class="flex items-center justify-between rounded-xl border border-brand/20 bg-white/60 px-4 py-3">
              <span>Midi ouvert</span>
              <input id="midi-ouvert" type="checkbox" checked class="w-5 h-5" />
            </label>

            <label class="flex items-center justify-between rounded-xl border border-brand/20 bg-white/60 px-4 py-3">
              <span>Soir ouvert</span>
              <input id="soir-ouvert" type="checkbox" checked class="w-5 h-5" />
            </label>
          </div>

          <div class="mt-5 text-right">
            <button type="submit"
              class="font-limelight bg-brand text-white px-6 py-3 rounded-xl hover:bg-[var(--color-copper)] transition">
              Enregistrer
            </button>
          </div>

          <p id="form-message" class="mt-3 text-sm text-right"></p>
        </form>

        <div class="mt-10">
          <h2 class="font-limelight text-3xl text-brand uppercase">
            Exceptions enregistrées
          </h2>

          <div id="exceptions-list" class="mt-5 space-y-3 text-left"></div>
        </div>
      </div>
    </div>
  </section>

  <script>
    import { supabase } from "../../lib/supabaseClient.js";

    const loginBox = document.getElementById("login-box");
    const adminBox = document.getElementById("admin-box");
    const loginBtn = document.getElementById("login-btn");
    const logoutBtn = document.getElementById("logout-btn");
    const loginMessage = document.getElementById("login-message");

    const form = document.getElementById("exception-form");
    const dateInput = document.getElementById("date-service");
    const selectedDateLabel = document.getElementById("selected-date-label");
    const midiInput = document.getElementById("midi-ouvert");
    const soirInput = document.getElementById("soir-ouvert");
    const raisonInput = document.getElementById("raison");
    const closeDayBtn = document.getElementById("close-day");
    const closeLunchBtn = document.getElementById("close-lunch");
    const closeDinnerBtn = document.getElementById("close-dinner");
    const openAllBtn = document.getElementById("open-all");
    const formMessage = document.getElementById("form-message");
    const list = document.getElementById("exceptions-list");
    const calendarTitle = document.getElementById("calendar-title");
    const calendarGrid = document.getElementById("calendar-grid");
    const prevMonthBtn = document.getElementById("prev-month");
    const nextMonthBtn = document.getElementById("next-month");
    const bookingEnabledInput = document.getElementById("booking-enabled");
const bookingMessageInput = document.getElementById("booking-message");
const saveBookingSettingsBtn = document.getElementById("save-booking-settings");
const bookingSettingsMessage = document.getElementById("booking-settings-message");

    let exceptions = [];
    let currentMonth = new Date();

    function formatDate(dateStr) {
      const date = new Date(dateStr + "T00:00:00");
      return date.toLocaleDateString("fr-FR", {
        weekday: "long",
        day: "numeric",
        month: "long",
        year: "numeric",
      });
    }

    async function checkSession() {
      const { data } = await supabase.auth.getSession();

      if (data.session) {
        loginBox.classList.add("hidden");
        adminBox.classList.remove("hidden");
        await loadBookingSettings();
await loadExceptions();
      } else {
        loginBox.classList.remove("hidden");
        adminBox.classList.add("hidden");
      }
    }
function toDateKey(date) {
  const y = date.getFullYear();
  const m = String(date.getMonth() + 1).padStart(2, "0");
  const d = String(date.getDate()).padStart(2, "0");
  return `${y}-${m}-${d}`;
}

function formatMonth(date) {
  return date.toLocaleDateString("fr-FR", {
    month: "long",
    year: "numeric",
  });
}

function getExceptionForDate(dateKey) {
  return exceptions.find((e) => e.date_service === dateKey);
}

function renderCalendar() {
  if (!calendarTitle || !calendarGrid) return;

  calendarTitle.textContent = formatMonth(currentMonth).toUpperCase();
  calendarGrid.innerHTML = "";

  const year = currentMonth.getFullYear();
  const month = currentMonth.getMonth();

  const firstDay = new Date(year, month, 1);
  const lastDay = new Date(year, month + 1, 0);

  let startOffset = firstDay.getDay() - 1;
  if (startOffset < 0) startOffset = 6;

  for (let i = 0; i < startOffset; i++) {
    calendarGrid.insertAdjacentHTML("beforeend", `<div></div>`);
  }

  for (let day = 1; day <= lastDay.getDate(); day++) {
    const date = new Date(year, month, day);
    const dateKey = toDateKey(date);
    const exception = getExceptionForDate(dateKey);

    let status = "";
    let statusClass = "border-brand/15 bg-white/50 text-slate-700";

    if (exception) {
      if (!exception.midi_ouvert && !exception.soir_ouvert) {
        status = "Fermé";
        statusClass = "border-red-300 bg-red-100 text-red-800";
      } else if (!exception.midi_ouvert) {
        status = "Midi fermé";
        statusClass = "border-orange-300 bg-orange-100 text-orange-800";
      } else if (!exception.soir_ouvert) {
        status = "Soir fermé";
        statusClass = "border-orange-300 bg-orange-100 text-orange-800";
      } else {
        status = "Ouvert";
        statusClass = "border-green-300 bg-green-100 text-green-800";
      }
    }

    calendarGrid.insertAdjacentHTML("beforeend", `
      <button
        type="button"
        data-date="${dateKey}"
        class="calendar-day min-h-[86px] rounded-xl border p-2 text-left transition ${statusClass}"
      >
        <div class="font-bold text-lg">${day}</div>
        ${status ? `<div class="mt-2 text-xs font-bold">${status}</div>` : ""}
        ${exception?.raison ? `<div class="mt-1 text-[11px] line-clamp-2">${exception.raison}</div>` : ""}
      </button>
    `);
  }

  document.querySelectorAll(".calendar-day").forEach((btn) => {
    btn.addEventListener("click", () => {
      dateInput.value = btn.dataset.date;

      const exception = getExceptionForDate(btn.dataset.date);

      if (exception) {
        midiInput.checked = exception.midi_ouvert;
        soirInput.checked = exception.soir_ouvert;
        raisonInput.value = exception.raison || "";
      }
    });
  });
}
async function loadBookingSettings() {
  const { data, error } = await supabase
    .from("reservation_settings")
    .select("*")
    .eq("key", "online_booking")
    .single();

  if (error) {
    console.error("Erreur réglages réservation :", error);
    return;
  }

  const value = data?.value || {};

  bookingEnabledInput.checked = value.enabled !== false;
  bookingMessageInput.value =
    value.message ||
    "La réservation en ligne est actuellement en maintenance. Veuillez nous appeler au 05 58 85 92 72 pour toute réservation. Merci.";
}

async function saveBookingSettings() {
  bookingSettingsMessage.textContent = "";

  const payload = {
    key: "online_booking",
    value: {
      enabled: bookingEnabledInput.checked,
      message: bookingMessageInput.value.trim(),
    },
    updated_at: new Date().toISOString(),
  };

  const { error } = await supabase
    .from("reservation_settings")
    .upsert(payload, { onConflict: "key" });

  if (error) {
    bookingSettingsMessage.textContent = "Erreur : " + error.message;
    bookingSettingsMessage.className = "mt-3 text-sm text-right text-red-700";
    return;
  }

  bookingSettingsMessage.textContent = "Réglage enregistré.";
  bookingSettingsMessage.className = "mt-3 text-sm text-right text-green-700";
}
    async function loadExceptions() {
      list.innerHTML = `<p class="text-right text-slate-600">Chargement...</p>`;

      const { data, error } = await supabase
        .from("reservation_exceptions")
        .select("*")
        .order("date_service", { ascending: true });

      if (error) {
        list.innerHTML = `<p class="text-right text-red-700">Erreur : ${error.message}</p>`;
        return;
      }
        exceptions = data || [];
        renderCalendar();
      if (!data.length) {
        list.innerHTML = `
          <div class="rounded-2xl soft-border bg-white/40 p-5 text-right">
            Aucune exception enregistrée.
          </div>
        `;
        return;
      }

      list.innerHTML = data.map((e) => `
        <article class="rounded-2xl soft-border bg-white/50 p-5" data-id="${e.id}">
          <div class="flex flex-col md:flex-row md:justify-between gap-3">
            <div>
              <p class="font-limelight text-2xl text-brand">
  ${new Date(e.date_service + "T00:00:00").toLocaleDateString("fr-FR", {
    weekday: "long"
  }).toUpperCase()}
</p>

<p class="text-lg text-slate-700">
  ${new Date(e.date_service + "T00:00:00").toLocaleDateString("fr-FR", {
    day: "numeric",
    month: "long",
    year: "numeric"
  })}
</p>
              <p class="text-slate-700 mt-1">
                Midi : <strong>${e.midi_ouvert ? "ouvert" : "fermé"}</strong>
                · Soir : <strong>${e.soir_ouvert ? "ouvert" : "fermé"}</strong>
              </p>
              ${e.raison ? `<p class="text-sm text-slate-600 mt-1">${e.raison}</p>` : ""}
            </div>

            <div class="text-right">
              <button data-action="delete"
                class="delete-btn rounded-xl border border-red-700 text-red-700 px-4 py-2 hover:bg-red-700 hover:text-white transition">
                Supprimer
              </button>
            </div>
          </div>
        </article>
      `).join("");

      document.querySelectorAll(".delete-btn").forEach((btn) => {
        btn.addEventListener("click", deleteException);
      });
    }

    async function deleteException(event) {
      const article = event.currentTarget.closest("article");
      const id = article.dataset.id;

      if (!confirm("Supprimer cette exception ?")) return;

      const { error } = await supabase
        .from("reservation_exceptions")
        .delete()
        .eq("id", id);

      if (error) {
        alert("Erreur : " + error.message);
        return;
      }

      await loadExceptions();
    }

    form?.addEventListener("submit", async (event) => {
      event.preventDefault();

      formMessage.textContent = "";

      const payload = {
        date_service: dateInput.value,
        midi_ouvert: midiInput.checked,
        soir_ouvert: soirInput.checked,
        raison: raisonInput.value.trim(),
      };

      const { error } = await supabase
        .from("reservation_exceptions")
        .upsert(payload, { onConflict: "date_service" });

      if (error) {
        formMessage.textContent = "Erreur : " + error.message;
        formMessage.className = "mt-3 text-sm text-right text-red-700";
        return;
      }

      form.reset();
      midiInput.checked = true;
      soirInput.checked = true;

      formMessage.textContent = "Exception enregistrée.";
      formMessage.className = "mt-3 text-sm text-right text-green-700";

      await loadExceptions();
    });

    loginBtn?.addEventListener("click", async () => {
      loginMessage.textContent = "";

      const email = document.getElementById("login-email").value;
      const password = document.getElementById("login-password").value;

      const { error } = await supabase.auth.signInWithPassword({
        email,
        password,
      });

      if (error) {
        loginMessage.textContent = "Connexion impossible : " + error.message;
        return;
      }

      await checkSession();
    });

    logoutBtn?.addEventListener("click", async () => {
      await supabase.auth.signOut();
      await checkSession();
    });
closeDayBtn?.addEventListener("click", () => {
  midiInput.checked = false;
  soirInput.checked = false;
});

closeLunchBtn?.addEventListener("click", () => {
  midiInput.checked = false;
  soirInput.checked = true;
});

closeDinnerBtn?.addEventListener("click", () => {
  midiInput.checked = true;
  soirInput.checked = false;
});

openAllBtn?.addEventListener("click", () => {
  midiInput.checked = true;
  soirInput.checked = true;
});
dateInput?.addEventListener("change", () => {
  if (!dateInput.value || !selectedDateLabel) return;

  selectedDateLabel.textContent = new Date(
    dateInput.value + "T00:00:00"
  ).toLocaleDateString("fr-FR", {
    weekday: "long",
    day: "numeric",
    month: "long",
    year: "numeric",
  });
});
prevMonthBtn?.addEventListener("click", () => {
  currentMonth = new Date(currentMonth.getFullYear(), currentMonth.getMonth() - 1, 1);
  renderCalendar();
});

nextMonthBtn?.addEventListener("click", () => {
  currentMonth = new Date(currentMonth.getFullYear(), currentMonth.getMonth() + 1, 1);
  renderCalendar();
});
saveBookingSettingsBtn?.addEventListener("click", saveBookingSettings);
    checkSession();
  </script>
</SidebarLayout>