---
import SidebarLayout from "../layouts/SidebarLayout.astro";
import { execSync } from "node:child_process";

const title = "La Régence — Bar Brasserie Restaurant à Mont-de-Marsan";
const description = "La Régence est un restaurant brasserie à Mont-de-Marsan, situé en centre-ville. Menu du midi, carte de brasserie, tapas, cocktails, bières pression et vins du lundi au samedi.";
const menuFile = "public/menu-du-jour.png";

// Format FR affiché
function formatDateFR(date) {
  const str = date.toLocaleDateString("fr-FR", {
    weekday: "long",
    day: "numeric",
    month: "long",
  });

  return str.charAt(0).toUpperCase() + str.slice(1);
}

function getMenuGitDate() {
  try {
    const gitDate = execSync(
      `git log -1 --format=%cI -- "${menuFile}"`,
      { encoding: "utf-8" }
    ).trim();

    if (!gitDate) throw new Error("No git date found");
    return gitDate;
  } catch {
    return new Date().toISOString();
  }
}

const menuGitDate = getMenuGitDate();
const menuDate = formatDateFR(new Date(menuGitDate));
const menuImage = `/menu-du-jour.png?v=${encodeURIComponent(menuGitDate)}`;
const restaurantSchema = {
  "@context": "https://schema.org",
  "@type": "Restaurant",
  "@id": "https://laregencemdm.fr/#restaurant",
  "name": "La Régence",
  "url": "https://laregencemdm.fr/",
  "telephone": "+33558859272",
  "image": [
    "https://laregencemdm.fr/contact-grande.jpg",
    "https://laregencemdm.fr/contact-petite.jpg"
  ],
  "description": "La Régence est un restaurant brasserie situé en centre-ville de Mont-de-Marsan. Cuisine de brasserie, menu du midi, tapas, cocktails, bières pression et vins du lundi au samedi.",
  "servesCuisine": [
    "Cuisine française",
    "Brasserie",
    "Tapas"
  ],
  "priceRange": "€€",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "2 rue Léon Gambetta",
    "postalCode": "40000",
    "addressLocality": "Mont-de-Marsan",
    "addressCountry": "FR"
  },
  "openingHoursSpecification": [
    {
      "@type": "OpeningHoursSpecification",
      "dayOfWeek": [
        "Monday",
        "Tuesday",
        "Wednesday",
        "Thursday",
        "Friday",
        "Saturday"
      ],
      "opens": "07:30",
      "closes": "00:00"
    }
  ],
  "menu": "https://laregencemdm.fr/menu/",
  "acceptsReservations": true,
  "sameAs": [
    "https://www.instagram.com/la_regence_mdm/",
    "https://www.facebook.com/LaRegenceMDM/"
  ]
};
---

<SidebarLayout {title} {description} active="accueil">
  <script
    is:inline
    type="application/ld+json"
    set:html={JSON.stringify(restaurantSchema)}
  ></script>


  <!-- ========= SPLASH ========= -->
  <div
    id="splash"
    class="fixed inset-0 z-50 bg-brand text-[var(--color-bg)]
           flex flex-col items-center justify-center
           transform-gpu translate-y-0 transition-transform duration-[1800ms] ease-out"
  >
    <div class="absolute left-0 right-0" style="top:90%; height:3px; background:#a3742c;"></div>

    <div class="absolute w-full text-center text-sm opacity-80 flex flex-col items-center" style="top:92%;">
      <img src="/logo.png" alt="La Régence" class="w-6 h-6 mb-1 opacity-90" />
      <p>© La Régence 2025</p>
    </div>

    <div class="flex flex-col items-center gap-5 font-splash fade-in-contents">
      <img 
        src="/logo.png" 
        alt="La Régence" 
        class="w-60 h-60 md:w-72 md:h-72 lg:w-80 lg:h-80 object-contain" 
      />
      <p class="text-2xl md:text-3xl text-center">
        Bar-Brasserie à Mont-de-Marsan
      </p>
    </div>
  </div>

  <!-- ========= CONTENU ========= -->
  <div id="page-wrap">
    <section class="w-full md:h-[calc(100dvh-24px)] px-4 xl:px-6 py-3 overflow-hidden">

      <div class="grid h-full grid-cols-[minmax(280px,1fr)_minmax(0,1fr)] gap-4 xl:gap-6">

        <!-- ===== TEXTE ===== -->
        <div class="min-h-0 flex">
          <div class="w-full max-w-prose md:max-w-xl mx-auto text-center md:text-right px-2 md:px-5 flex flex-col justify-end pb-6 md:pb-8">

            <div class="space-y-4">
              <h1 class="font-limelight text-3xl sm:text-3xl md:text-3xl text-brand leading-tight uppercase regence-title">
  Bar Restaurant
</h1>
<h1 class="font-limelight text-3xl sm:text-4xl md:text-5xl text-brand leading-tight uppercase regence-title">
La Régence
</h1>
              <p class="text-slate-700 italic text-base leading-snug">
                « Au cœur de Mont-de-Marsan, là où le Midou et la Douze se rejoignent pour former la Midouze… »
              </p>

              <p class="text-slate-700 leading-relaxed text-base">
  La Régence est un <strong>bar restaurant brasserie</strong> situé en <strong>centre-ville de Mont-de-Marsan</strong>, au 2 rue Léon Gambetta. Depuis 1988, cette adresse fait partie du quotidien des Montois. En 2024, deux frères reprennent l’établissement et lui donnent un nouveau souffle, fidèle à son esprit convivial et chaleureux.
</p>

              <p class="text-slate-700 leading-relaxed text-base">
                Notre cuisine, inspirée de la tradition brasserie, se veut généreuse, accessible et préparée avec soin, à partir de produits frais et de recettes travaillées sur place. Le midi, nous vous accueillons pour une pause déjeuner autour de notre <strong> menu du jour </strong>et de notre carte. Le soir, La Régence devient une adresse idéale pour dîner, partager des tapas, boire un verre, découvrir nos cocktails, nos bières pression et nos vins.
              </p>

              <p class="text-slate-700 leading-relaxed text-base">
                Que ce soit pour un café le matin, un déjeuner en centre-ville, un apéritif entre amis ou un dîner à Mont-de-Marsan, notre équipe vous accueille du lundi au samedi dans une ambiance simple, conviviale et authentique.
              </p>

              <p class="text-slate-700">
                <a href="tel:+33558859272" class="underline">
                  Réservez votre table en ligne ou par téléphone au 05&nbsp;58&nbsp;85&nbsp;92&nbsp;72
                </a>
              </p>
            </div>

          </div>
        </div>

        <!-- ===== IMAGES ===== -->
        <div class="min-h-0 md:min-w-0 md:overflow-hidden">

          <div class="hidden md:grid md:gap-6 md:grid-cols-1 xl:grid-cols-3 xl:grid-rows-10 md:h-full">

            <!-- Grande image -->
            <div class="xl:col-span-2 xl:row-span-10 rounded-2xl soft-border overflow-hidden">
              <img src="/grande.jpg" class="w-full md:h-[60vh] xl:h-full object-cover" />
            </div>

            <div class="hidden xl:block xl:col-span-1 xl:row-span-2"></div>

            <!-- Menu du jour -->
            <div class="relative group cursor-pointer rounded-2xl soft-border overflow-hidden xl:col-span-1 xl:row-span-4 js-menu-thumb" data-img={menuImage}>
              
              <img
                src={menuImage}
                alt={`Menu du ${menuDate}`}
                class="w-full md:h-[28vh] xl:h-full object-cover transition duration-300 group-hover:scale-105"
              />

              <div class="hidden xl:flex absolute inset-0 items-center justify-center pointer-events-none">
            <span class="text-white text-base md:text-lg font-bold bg-black/45 px-3 py-1.5 rounded text-center">
            Menu du {menuDate}
            </span>
              </div>
            </div>

            <!-- Petite image -->
            <div class="rounded-2xl soft-border overflow-hidden xl:col-span-1 xl:row-span-4">
              <img src="/petite2.jpg" class="w-full md:h-[28vh] xl:h-full object-cover" />
            </div>

          </div>

          <!-- MOBILE -->
          <div class="xl:hidden flex flex-col gap-4">

            <div id="g-wrap" class="rounded-2xl soft-border overflow-hidden">
              <img id="g-img" src="/grande.jpg" class="w-full h-auto object-contain" />
            </div>

            <div
  class="relative rounded-2xl soft-border overflow-hidden js-menu-thumb cursor-pointer"
  data-img={menuImage}
>
  <div id="match-size-1" class="w-full">
    <img
      src={menuImage}
      alt={`Menu du ${menuDate}`}
      class="w-full h-full object-cover object-center"
    />
  </div>

  <div class="absolute inset-0 flex items-center justify-center pointer-events-none">
    <span class="text-white text-base md:text-lg font-bold bg-black/45 px-3 py-1.5 rounded text-center">
      Menu du {menuDate}
    </span>
  </div>
</div>

            <div class="rounded-2xl soft-border overflow-hidden">
              <div id="match-size-2" class="w-full">
                <img src="/petite2.jpg" class="w-full h-full object-cover" />
              </div>
            </div>

          </div>

        </div>
      </div>
    </section>

    <!-- LIGHTBOX -->
    <div id="menu-du-jour-lightbox" class="fixed inset-0 hidden items-center justify-center z-[60]">
      <div id="lb-backdrop" class="absolute inset-0 bg-black/60 backdrop-blur-sm"></div>
      <div id="lb-figure" class="relative">
        <img id="lb-img" src={menuImage} class="max-w-[90vw] max-h-[85vh] rounded-2xl shadow-xl" />
      </div>
    </div>

  </div>

  <!-- SCRIPT LIGHTBOX -->
  <script is:inline>
  // Splash
  (function () {
    const s = document.getElementById('splash');
    if (!s) return;
    const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    const go = () => {
      if (prefersReduced) {
        s.remove();
        return;
      }
      s.classList.add('slide-up-out');
      s.addEventListener('transitionend', () => s.remove(), { once: true });
    };

    window.addEventListener('load', () => setTimeout(go, 1500));
  })();

  // Lightbox (multi-vignettes)
  (function () {
    const thumbs   = Array.from(document.querySelectorAll(".js-menu-thumb"));
    const lightbox = document.getElementById("menu-du-jour-lightbox");
    const backdrop = document.getElementById("lb-backdrop");
    const figure   = document.getElementById("lb-figure");
    const img      = document.getElementById("lb-img");
    if (!thumbs.length || !lightbox || !backdrop || !figure || !img) return;

    function openLB(src) {
      if (src) img.src = src;
      lightbox.classList.remove("hidden");
      lightbox.classList.add("flex");
      img.style.filter = "none";
      img.style.webkitFilter = "none";
      requestAnimationFrame(() => {
        backdrop.classList.add("opacity-100");
        figure.classList.remove("opacity-0", "scale-95", "translate-y-1");
        figure.classList.add("opacity-100", "scale-100", "translate-y-0");
      });
    }

    function closeLB() {
      figure.classList.add("opacity-0", "scale-95", "translate-y-1");
      figure.classList.remove("opacity-100", "scale-100", "translate-y-0");
      backdrop.classList.remove("opacity-100");
      setTimeout(() => {
        lightbox.classList.add("hidden");
        lightbox.classList.remove("flex");
      }, 300);
    }

    thumbs.forEach(t => {
      t.addEventListener("click", () => openLB(t.dataset.img || "/menu-du-jour.png"));
    });

    lightbox.addEventListener("click", (e) => {
      if (e.target === img) return;
      closeLB();
    });

    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape" && !lightbox.classList.contains("hidden")) closeLB();
    });
  })();

  // Égaliser les hauteurs sous 1280px
  (function () {
    const mq = window.matchMedia('(max-width: 1279px)');
    const gImg = document.getElementById('g-img');
    const matchEls = [
      document.getElementById('match-size-1'),
      document.getElementById('match-size-2'),
    ].filter(Boolean);

    if (!gImg || !matchEls.length) return;

    function syncHeights() {
      if (!mq.matches) {
        matchEls.forEach(el => { el.style.height = ''; });
        return;
      }

      const rect = gImg.getBoundingClientRect();
      if (rect.height > 0) {
        const h = rect.height + 'px';
        matchEls.forEach(el => { el.style.height = h; });
      }
    }

    gImg.addEventListener('load', syncHeights);
    window.addEventListener('load', syncHeights);
    window.addEventListener('resize', syncHeights);

    setTimeout(syncHeights, 50);
    setTimeout(syncHeights, 250);
  })();
</script>


</SidebarLayout>