---
import SidebarLayout from "../layouts/SidebarLayout.astro";

const title = "Réservation — La Régence";
const description = "Demande de réservation à La Régence, bar-brasserie à Mont-de-Marsan.";
---

<SidebarLayout {title} {description} active="reservation">
  <section class="min-h-screen w-full bg-[var(--color-bg)] px-6 py-10">
    <div class="max-w-3xl ml-auto text-right md:pr-12">
      <h1 class="font-limelight text-5xl text-brand tracking-wide uppercase">
        Réservation
      </h1>

      <p class="mt-4 text-slate-700">
        Votre demande sera étudiée par notre équipe. Vous recevrez une confirmation après validation.
      </p>
<div id="booking-disabled-box" class="hidden rounded-2xl soft-border bg-white/60 p-8 text-right">
  <h2 class="font-limelight text-3xl text-brand uppercase">
    Réservation en ligne indisponible
  </h2>

  <p id="booking-disabled-message" class="mt-4 text-lg text-slate-700"></p>

  <a href="tel:+33558859272"
    class="inline-block mt-6 font-limelight bg-brand text-white px-6 py-3 rounded-xl hover:bg-[var(--color-copper)] transition">
    Appeler La Régence
  </a>
</div>

      <form id="reservation-form" class="mt-10 space-y-6 text-left">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <label class="block">
            <span class="text-sm uppercase text-slate-600">Date</span>
            <input
              type="date"
              name="date_service"
              required
              class="mt-1 w-full rounded-xl border border-brand/20 bg-white/60 px-4 py-3"
            />
            <p id="date-message" class="mt-2 text-sm text-red-700"></p>
          </label>

          <label class="block">
            <span class="text-sm uppercase text-slate-600">Service</span>
            <select
              name="service"
              id="service"
              required
              class="mt-1 w-full rounded-xl border border-brand/20 bg-white/60 px-4 py-3"
            >
              <option value="">Choisir</option>
              <option value="midi">Midi</option>
              <option value="soir">Soir</option>
            </select>
          </label>

          <label class="block">
            <span class="text-sm uppercase text-slate-600">Heure</span>
            <select
              name="heure"
              id="heure"
              required
              class="mt-1 w-full rounded-xl border border-brand/20 bg-white/60 px-4 py-3"
            >
              <option value="">Choisissez d’abord un service</option>
            </select>
          </label>

          <label class="block">
            <span class="text-sm uppercase text-slate-600">Nombre de personnes</span>
            <input
              type="number"
              name="nb_personnes"
              min="1"
              max="8"
              required
              class="mt-1 w-full rounded-xl border border-brand/20 bg-white/60 px-4 py-3"
            />
          </label>

          <label class="block md:col-span-2">
            <span class="text-sm uppercase text-slate-600">Préférence de salle</span>
            <select
              name="preference_salle"
              required
              class="mt-1 w-full rounded-xl border border-brand/20 bg-white/60 px-4 py-3"
            >
              <option value="peu_importe">Peu importe</option>
              <option value="salle_bas">Salle du bas</option>
              <option value="etage">Étage</option>
              <option value="terrasse">Terrasse</option>
            </select>
          </label>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <label class="block">
            <span class="text-sm uppercase text-slate-600">Nom</span>
            <input
              type="text"
              name="nom"
              required
              class="mt-1 w-full rounded-xl border border-brand/20 bg-white/60 px-4 py-3"
            />
          </label>

          <label class="block">
            <span class="text-sm uppercase text-slate-600">Prénom</span>
            <input
              type="text"
              name="prenom"
              class="mt-1 w-full rounded-xl border border-brand/20 bg-white/60 px-4 py-3"
            />
          </label>

          <label class="block">
            <span class="text-sm uppercase text-slate-600">Téléphone</span>
            <input
              type="tel"
              name="telephone"
              required
              class="mt-1 w-full rounded-xl border border-brand/20 bg-white/60 px-4 py-3"
            />
          </label>

          <label class="block">
            <span class="text-sm uppercase text-slate-600">Email</span>
            <input
              type="email"
              name="email"
              required
              class="mt-1 w-full rounded-xl border border-brand/20 bg-white/60 px-4 py-3"
            />
          </label>
        </div>

        <label class="block">
          <span class="text-sm uppercase text-slate-600">Commentaire</span>
          <textarea
            name="commentaire_client"
            rows="4"
            class="mt-1 w-full rounded-xl border border-brand/20 bg-white/60 px-4 py-3"
            placeholder="Allergie, poussette, demande particulière..."
          ></textarea>
        </label>

        <div class="text-right">
          <button
            type="submit"
            id="submit-btn"
            class="font-limelight bg-brand text-white px-6 py-3 rounded-xl hover:bg-[var(--color-copper)] transition"
          >
            Envoyer ma demande
          </button>
        </div>

        <p id="form-message" class="text-right text-sm"></p>
      </form>
    </div>
  </section>

  <script>
    import { supabase } from "../lib/supabaseClient.js";

const bookingDisabledBox = document.getElementById("booking-disabled-box");
const bookingDisabledMessage = document.getElementById("booking-disabled-message");
    const form = document.getElementById("reservation-form");
    const serviceSelect = document.getElementById("service");
    const heureSelect = document.getElementById("heure");
    const message = document.getElementById("form-message");
    const submitBtn = document.getElementById("submit-btn");
    const dateMessage = document.getElementById("date-message");

    const horaires = {
      midi: ["12:00", "12:15", "12:30", "12:45", "13:00", "13:15", "13:30"],
      soir: ["19:00", "19:15", "19:30", "19:45", "20:00", "20:15", "20:30", "20:45", "21:00", "21:15", "21:30"],
    };

    const dateInput = form?.querySelector('input[name="date_service"]');
    if (dateInput) {
      const today = new Date().toISOString().split("T")[0];
      dateInput.setAttribute("min", today);
    }

    function updateHeures() {
  const service = serviceSelect?.value;

  if (!heureSelect) return;

  heureSelect.innerHTML = "";

  if (!service || !horaires[service]) {
    heureSelect.innerHTML = '<option value="">Choisissez d’abord un service</option>';
    return;
  }

  heureSelect.innerHTML = '<option value="">Choisir une heure</option>';

  horaires[service].forEach((h) => {
  if (isToday(dateInput?.value) && isPastSlot(h)) {
    return;
  }

  const option = document.createElement("option");
  option.value = h;
  option.textContent = h.replace(":", "h");
  heureSelect.appendChild(option);
});
}

let reservationExceptions = [];

async function loadReservationExceptions() {
  const { data, error } = await supabase
    .from("reservation_exceptions")
    .select("*");

  if (error) {
    console.error("Erreur chargement exceptions :", error);
    reservationExceptions = [];
    return;
  }

  reservationExceptions = data || [];
  validateDateSelection();
}

function getExceptionForDate(dateStr) {
  return reservationExceptions.find((e) => e.date_service === dateStr);
}

serviceSelect?.addEventListener("change", () => {
  updateHeures();
  validateDateSelection();
});

serviceSelect?.addEventListener("input", () => {
  updateHeures();
  validateDateSelection();
});

updateHeures();

function isSunday(dateStr) {
  if (!dateStr) return false;

  const date = new Date(dateStr + "T00:00:00");
  return date.getDay() === 0;
}

function isToday(dateStr) {
  if (!dateStr) return false;

  const today = new Date();
  const selected = new Date(dateStr + "T00:00:00");

  return (
    selected.getFullYear() === today.getFullYear() &&
    selected.getMonth() === today.getMonth() &&
    selected.getDate() === today.getDate()
  );
}

function isPastSlot(heure) {
  if (!heure) return true;

  const now = new Date();
  const [hour, minute] = heure.split(":").map(Number);

  if (hour < now.getHours()) return true;
  if (hour === now.getHours() && minute <= now.getMinutes()) return true;

  return false;
}

function isAfterMidiCutoff() {
  const now = new Date();
  return now.getHours() > 13 || (now.getHours() === 13 && now.getMinutes() >= 30);
}

function isAfterSoirCutoff() {
  const now = new Date();
  return now.getHours() > 21 || (now.getHours() === 21 && now.getMinutes() >= 30);
}

function validateDateSelection() {
  const selectedDate = dateInput?.value;
  const selectedService = serviceSelect?.value;
  const exception = getExceptionForDate(selectedDate);

  if (!dateMessage || !submitBtn) return true;

  dateMessage.textContent = "";
  submitBtn.disabled = false;

  let midiOuvert = !isSunday(selectedDate);
  let soirOuvert = !isSunday(selectedDate);

  if (exception) {
    midiOuvert = exception.midi_ouvert;
    soirOuvert = exception.soir_ouvert;
  }

  if (selectedService === "midi" && !midiOuvert) {
    dateMessage.textContent =
      exception?.raison ||
      "Les réservations du midi sont fermées ce jour-là. Merci de nous appeler au 05 58 85 92 72.";

    submitBtn.disabled = true;
    return false;
  }

  if (selectedService === "soir" && !soirOuvert) {
    dateMessage.textContent =
      exception?.raison ||
      "Les réservations du soir sont fermées ce jour-là. Merci de nous appeler au 05 58 85 92 72.";

    submitBtn.disabled = true;
    return false;
  }

  if (!selectedService && isSunday(selectedDate) && !exception) {
    dateMessage.textContent =
      "Le restaurant est fermé le dimanche. Pour une demande particulière, merci de nous appeler au 05 58 85 92 72.";

    submitBtn.disabled = true;
    return false;
  }

  if (
    selectedService === "midi" &&
    isToday(selectedDate) &&
    isAfterMidiCutoff()
  ) {
    dateMessage.textContent =
      "Les réservations pour ce midi sont désormais fermées. Merci de nous appeler au 05 58 85 92 72.";

    submitBtn.disabled = true;
    return false;
  }

  if (
    selectedService === "soir" &&
    isToday(selectedDate) &&
    isAfterSoirCutoff()
  ) {
    dateMessage.textContent =
      "Les réservations pour ce soir sont désormais fermées. Merci de nous appeler au 05 58 85 92 72.";

    submitBtn.disabled = true;
    return false;
  }

  return true;
}

dateInput?.addEventListener("change", () => {
  updateHeures();
  validateDateSelection();
});

loadReservationExceptions();

form?.addEventListener("submit", async (event) => {
      event.preventDefault();
      if (!validateDateSelection()) return;

      message.textContent = "";
      message.className = "text-right text-sm";
      submitBtn.disabled = true;
      submitBtn.textContent = "Envoi en cours...";

      const formData = new FormData(form);

      const reservation = {
        date_service: formData.get("date_service"),
        service: formData.get("service"),
        heure: formData.get("heure"),
        nb_personnes: Number(formData.get("nb_personnes")),

        nom: String(formData.get("nom") || "").trim(),
        prenom: String(formData.get("prenom") || "").trim(),
        telephone: String(formData.get("telephone") || "").trim(),
        email: String(formData.get("email") || "").trim(),

        preference_salle: formData.get("preference_salle"),
        commentaire_client: String(formData.get("commentaire_client") || "").trim(),

        origine: "site",
        statut: "nouvelle",
        a_traiter: true,
      };

const createResponse = await fetch(
  "/.netlify/functions/create-reservation",
  {
    method: "POST",
    headers: {
      "Content-Type": "application/json",
    },
    body: JSON.stringify(reservation),
  }
);

const createResult = await createResponse.json();

if (!createResponse.ok) {
  console.error("Erreur création réservation :", createResult);

  message.textContent =
    "Erreur Supabase : " +
    (createResult.error || "Erreur inconnue");

  message.classList.add("text-red-700");
  submitBtn.disabled = false;
  submitBtn.textContent = "Envoyer ma demande";
  return;
}

const data = createResult.reservation;

try {
  const emailResponse = await fetch("/.netlify/functions/send-reservation-email", {
    method: "POST",
    headers: {
      "Content-Type": "application/json",
    },
    body: JSON.stringify({
      type: "new_reservation_admin",
      reservation: data,
    }),
  });

  const emailResult = await emailResponse.json();

  console.log("Réponse fonction email :", emailResult);

  if (!emailResponse.ok) {
    console.error("Erreur fonction email :", emailResult);
    alert("Réservation enregistrée, mais mail non envoyé : " + (emailResult.error || "erreur inconnue"));
  }
} catch (emailError) {
  console.error("Erreur envoi mail admin :", emailError);
  alert("Réservation enregistrée, mais erreur mail.");
}
try {
 const pushDate = new Date(data.date_service + "T00:00:00").toLocaleDateString("fr-FR", {
  weekday: "long",
  day: "numeric",
  month: "long",
});

const pushNom = `${data.nom || ""} ${data.prenom || ""}`.trim();

await fetch("/.netlify/functions/send-push-notification", {
  method: "POST",
  headers: {
    "Content-Type": "application/json",
  },
  body: JSON.stringify({
    title: `Nouvelle réservation — ${pushNom || "Client"}`,
    body: `${data.nb_personnes} pers. — ${pushDate} — ${String(data.heure).slice(0, 5).replace(":", "h")}`,
    url: "/admin/reservations",
  }),
});
} catch (pushError) {
  console.error("Erreur notification push :", pushError);
}
      form.reset();
      heureSelect.innerHTML = '<option value="">Choisissez d’abord un service</option>';

      message.textContent = "Votre demande de réservation a bien été envoyée. Nous reviendrons vers vous pour confirmation.";
      message.classList.add("text-green-700");

      submitBtn.disabled = false;
      submitBtn.textContent = "Envoyer ma demande";
    });
  </script>
</SidebarLayout>